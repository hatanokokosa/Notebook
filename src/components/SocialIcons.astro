---
import config from "virtual:starlight/user-config";
import { Icon } from "@astrojs/starlight/components";

const locale = Astro.locals.starlightRoute.locale ?? config.defaultLocale.locale ?? "zh-cn";
const localizedRssHref = `/${locale}/blog/rss.xml`;
const links = (config.social ?? []).map((link) => (link.icon === "rss" ? { ...link, href: localizedRssHref } : link));
---

{
  links.length > 0 && (
    <>
      {links.map(({ label, href, icon }) => (
        <a key={href} {href} rel="me" class="sl-flex">
          <span class="sr-only">{label}</span>
          <Icon name={icon} />
        </a>
      ))}
    </>
  )
}

<style>
  @layer starlight.core {
    a {
      color: var(--sl-color-text-accent);
      padding: 0.5em;
      margin: -0.5em;
    }
    a:hover {
      color: var(--sl-color-white);
    }
  }
</style>
