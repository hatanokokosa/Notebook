---
import { createContentTerm } from "../lib/content-identity";

const { starlightRoute } = Astro.locals;
const pathname = Astro.url.pathname;

// comments: false?
const hasCommentsEnabled = starlightRoute?.entry?.data?.comments !== false;
const hasEntry = Boolean(starlightRoute?.entry);

// auto generated page?
const isBlogGeneratedPage =
  !hasEntry ||
  pathname === "/" ||
  pathname.endsWith("/blog") ||
  pathname.endsWith("/blog/") ||
  pathname.includes("/tags/") ||
  pathname.includes("/authors/");

// render!
const canRenderComments = hasCommentsEnabled && !isBlogGeneratedPage;
const contentId = starlightRoute?.entry?.data?.contentId;
const contentTerm = canRenderComments && contentId ? createContentTerm(contentId) : undefined;
const shouldRender = contentTerm !== undefined;
---

{
  shouldRender && (
    <>
      <div class="giscus-container" data-giscus-term={contentTerm} style="margin-top: 3rem;" />
      <script src="../plugins/giscus.ts" />
    </>
  )
}
