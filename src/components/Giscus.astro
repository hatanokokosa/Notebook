---
const { starlightRoute } = Astro.locals;
const pathname = Astro.url.pathname;

// comments: false?
const hasCommentsEnabled = starlightRoute?.entry?.data?.comments !== false;
const hasEntry = Boolean(starlightRoute?.entry);

// auto generated page?
const isBlogGeneratedPage =
  !hasEntry ||
  pathname === "/" ||
  pathname.endsWith("/blog") ||
  pathname.endsWith("/blog/") ||
  pathname.includes("/tags/") ||
  pathname.includes("/authors/");

// render!
const shouldRender = hasCommentsEnabled && !isBlogGeneratedPage;
---

{
  shouldRender && (
    <>
      <div class="giscus-container" style="margin-top: 3rem;" />
      <script src="../plugins/giscus.ts" />
    </>
  )
}
