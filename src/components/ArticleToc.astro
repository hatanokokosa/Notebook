---
import TocList from "./TocList.astro";
import { countTocItems, getUserTocItems } from "../lib/toc";

const { toc } = Astro.locals.starlightRoute;
const tocItems = toc ? getUserTocItems(toc.items) : [];
const tocItemCount = countTocItems(tocItems);
const shouldOpen = tocItemCount <= 5;
---

{
  toc && tocItemCount > 0 && (
    <details class="article-toc not-content" open={shouldOpen}>
      <summary>{Astro.locals.t("tableOfContents.onThisPage")}</summary>
      <div class="article-toc-content">
        <div class="article-toc-inner">
          <TocList toc={tocItems} />
        </div>
      </div>
    </details>
  )
}

<style>
  .article-toc {
    display: none;
  }

  @media (min-width: 72rem) {
    .article-toc {
      display: block;
      border: 1px solid var(--sl-color-hairline-light);
      padding: 0.75rem 1rem;
      background: var(--sl-color-bg);
    }
  }

  summary {
    display: flex;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
    color: var(--sl-color-white);
    cursor: pointer;
    font-weight: 600;
    line-height: var(--sl-line-height-headings);
    transition: color 180ms ease;
  }

  summary::marker,
  summary::-webkit-details-marker {
    display: none;
  }

  summary::after {
    content: "›";
    color: var(--sl-color-gray-3);
    font-size: 1.25rem;
    line-height: 1;
    transition: transform 220ms cubic-bezier(0.22, 1, 0.36, 1);
  }

  .article-toc[open]:not([data-closing]) summary::after {
    transform: rotateZ(90deg);
  }

  .article-toc-content {
    display: grid;
    grid-template-rows: 0fr;
    margin-top: 0;
    overflow: hidden;
    opacity: 0;
    transform: translateY(-0.25rem);
    visibility: hidden;
    transition:
      grid-template-rows 260ms cubic-bezier(0.22, 1, 0.36, 1),
      margin-top 260ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 180ms ease,
      transform 260ms cubic-bezier(0.22, 1, 0.36, 1),
      visibility 0s linear 260ms;
  }

  .article-toc[open]:not([data-closing]) .article-toc-content {
    grid-template-rows: 1fr;
    margin-top: 0.75rem;
    opacity: 1;
    transform: translateY(0);
    visibility: visible;
    transition-delay: 0s;
  }

  .article-toc-inner {
    min-height: 0;
    overflow: hidden;
  }

  .article-toc :global(a) {
    color: var(--sl-color-gray-2);
    font-size: var(--sl-text-base);
    text-decoration: none;
  }

  .article-toc :global(a:hover),
  .article-toc :global(a[aria-current="true"]) {
    color: var(--sl-color-white);
  }

  @media (prefers-reduced-motion: reduce) {
    summary,
    summary::after,
    .article-toc-content {
      transition: none;
    }

    .article-toc-content {
      transform: none;
    }
  }
</style>

<script>
  import { createToggleAnimation } from "../lib/details-animation";

  const articleTocAnimationMs = 260;
  const articleTocBoundAttr = "data-article-toc-bound";

  function setupArticleTocAnimations() {
    document.querySelectorAll<HTMLDetailsElement>(`.article-toc:not([${articleTocBoundAttr}])`).forEach((details) => {
      const summary = details.querySelector("summary");
      if (!summary) return;

      details.setAttribute(articleTocBoundAttr, "");

      const toggle = createToggleAnimation(
        details,
        () => {
          details.open = true;
        },
        () => {
          details.open = false;
        },
        articleTocAnimationMs,
      );

      summary.addEventListener("click", (event) => {
        event.preventDefault();
        toggle(!details.open || details.hasAttribute("data-closing"));
      });
    });
  }

  setupArticleTocAnimations();
  document.addEventListener("astro:page-load", setupArticleTocAnimations);
</script>
