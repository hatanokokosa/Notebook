---
import Default from "@astrojs/starlight/components/MarkdownContent.astro";
import BlogMarkdownContent from "../plugins/kokosa-blog/components/starlight/MarkdownContent.astro";
import ImageZoomer from "./ImageZoomer";
import DownloadOverlay from "./DownloadOverlay.astro";
import Giscus from "./Giscus.astro";
import ArticleToc from "./ArticleToc.astro";
import { applyStaticWatermarks } from "../lib/static-watermark";

const { starlightRoute } = Astro.locals;
const pathname = Astro.url.pathname;
const contentHtml = await Astro.slots.render("default");
const hasWatermarkEnabled = starlightRoute?.entry?.data?.watermark === true;
const renderedContentHtml = hasWatermarkEnabled ? await applyStaticWatermarks(contentHtml) : contentHtml;
const articleTocMarker = /<!--\s*toc\s*-->|<p>\s*(?:\[toc\]|::toc)\s*<\/p>/i;
const contentParts = renderedContentHtml.split(articleTocMarker);
const shouldInsertArticleToc = Boolean(starlightRoute?.toc) && contentParts.length > 1;
const isBlogPostPage = starlightRoute?.entry?.data?.date instanceof Date;
const isGeneratedBlogPage =
  pathname === "/" ||
  pathname.endsWith("/blog") ||
  pathname.endsWith("/blog/") ||
  pathname.includes("/tags/") ||
  pathname.includes("/authors/");
const shouldEnhanceImages = !isGeneratedBlogPage && /<img[\s>]/i.test(renderedContentHtml);
---

{shouldEnhanceImages && <ImageZoomer client:only="react" />}
{shouldEnhanceImages && <DownloadOverlay />}
{
  isBlogPostPage ? (
    <BlogMarkdownContent>
      {shouldInsertArticleToc ? (
        contentParts.map((part, index) => (
          <Fragment key={index}>
            {part && <Fragment set:html={part} />}
            {index < contentParts.length - 1 && <ArticleToc />}
          </Fragment>
        ))
      ) : (
        <Fragment set:html={renderedContentHtml} />
      )}
    </BlogMarkdownContent>
  ) : (
    <Default>
      {shouldInsertArticleToc ? (
        contentParts.map((part, index) => (
          <Fragment key={index}>
            {part && <Fragment set:html={part} />}
            {index < contentParts.length - 1 && <ArticleToc />}
          </Fragment>
        ))
      ) : (
        <Fragment set:html={renderedContentHtml} />
      )}
    </Default>
  )
}

<Giscus {...Astro.props} />

<style is:global>
  .fold-img {
    margin-block: 1.5rem;
    border: 1px solid var(--sl-color-hairline-light);
    padding: 0.75rem 1rem !important;
    background: var(--sl-color-bg);
    overflow: hidden;
  }
  .fold-img * {
    margin-top: 0 !important;
    margin-bottom: 0 !important;
  }
  .fold-img-desc {
    display: flex;
    gap: 1rem;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    user-select: none;
    color: var(--sl-color-white);
    font-weight: 600;
    line-height: var(--sl-line-height-headings);
    transition: opacity 180ms ease;
  }
  .fold-img-desc:hover {
    opacity: 0.7;
  }
  .fold-img-title {
    font-size: 1rem;
  }
  .fold-img-count {
    font-size: 0.85rem;
    color: var(--sl-color-gray-3);
    font-weight: 400;
  }
  .fold-img-content {
    max-height: 0;
    margin-top: 0;
    overflow: hidden;
    opacity: 0;
    visibility: hidden;
    transition:
      max-height 420ms cubic-bezier(0.22, 1, 0.36, 1),
      margin-top 420ms cubic-bezier(0.22, 1, 0.36, 1),
      opacity 180ms ease,
      visibility 0s linear 420ms;
  }
  .fold-img[data-spread="true"]:not([data-closing]) > .fold-img-content {
    max-height: 5000px;
    margin-top: 0.75rem !important;
    opacity: 1;
    visibility: visible;
    transition-delay: 0s;
  }
  .fold-img-grid {
    columns: 2;
    column-gap: 0.75rem;
  }
  .fold-img-grid > figure {
    break-inside: avoid;
    width: 100% !important;
    max-width: 100% !important;
    margin: 0 0 0.75rem !important;
  }
  .fold-img [data-dl-wrapper] {
    width: 100% !important;
    max-width: 100% !important;
  }
  .fold-img figcaption {
    margin-top: 0.5rem !important;
  }
  .fold-img img {
    width: 100%;
    height: auto;
    display: block;
    box-sizing: border-box;
  }
  @media (prefers-reduced-motion: reduce) {
    .fold-img-content {
      transition: none;
    }
  }
</style>

<script>
  import { createToggleAnimation } from "../lib/details-animation";

  const foldImgAnimationMs = 420;
  const foldImgBoundAttr = "data-fold-img-bound";

  function setupFoldImg() {
    document.querySelectorAll<HTMLElement>(`.fold-img:not([${foldImgBoundAttr}])`).forEach((el) => {
      const desc = el.querySelector<HTMLElement>(".fold-img-desc");
      if (!desc) return;

      el.setAttribute(foldImgBoundAttr, "");

      const toggle = createToggleAnimation(
        el,
        () => {
          el.setAttribute("data-spread", "true");
        },
        () => {
          el.setAttribute("data-spread", "false");
        },
        foldImgAnimationMs,
      );

      desc.addEventListener("click", (event) => {
        event.preventDefault();
        toggle(el.getAttribute("data-spread") === "false");
      });
    });
  }

  setupFoldImg();
  document.addEventListener("astro:page-load", setupFoldImg);
</script>
