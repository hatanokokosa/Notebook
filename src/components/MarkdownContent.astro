---
import Default from "@astrojs/starlight/components/MarkdownContent.astro";
import BlogMarkdownContent from "../plugins/kokosa-blog/components/starlight/MarkdownContent.astro";
import ImageZoomer from "./ImageZoomer";
import DownloadOverlay from "./DownloadOverlay";
import Giscus from "./Giscus.astro";
import ArticleToc from "./ArticleToc.astro";
import { applyStaticWatermarks } from "../lib/static-watermark";

const { starlightRoute } = Astro.locals;
const pathname = Astro.url.pathname;
const contentHtml = await Astro.slots.render("default");
const hasWatermarkEnabled = starlightRoute?.entry?.data?.watermark === true;
const hasDownloadEnabled = starlightRoute?.entry?.data?.download === true;
const renderedContentHtml = hasWatermarkEnabled ? await applyStaticWatermarks(contentHtml) : contentHtml;
const articleTocMarker = /<!--\s*toc\s*-->|<p>\s*(?:\[toc\]|::toc)\s*<\/p>/i;
const contentParts = renderedContentHtml.split(articleTocMarker);
const shouldInsertArticleToc = Boolean(starlightRoute?.toc) && contentParts.length > 1;
const isBlogPostPage = starlightRoute?.entry?.data?.date instanceof Date;
const isGeneratedBlogPage =
  pathname === "/" ||
  pathname.endsWith("/blog") ||
  pathname.endsWith("/blog/") ||
  pathname.includes("/tags/") ||
  pathname.includes("/authors/");
const shouldEnhanceImages = !isGeneratedBlogPage && /<img[\s>]/i.test(renderedContentHtml);
---

{shouldEnhanceImages && <ImageZoomer client:only="react" />}
{shouldEnhanceImages && <DownloadOverlay enabled={hasDownloadEnabled} client:only="react" />}
{
  isBlogPostPage ? (
    <BlogMarkdownContent>
      {shouldInsertArticleToc ? (
        contentParts.map((part, index) => (
          <>
            {part && <Fragment set:html={part} />}
            {index < contentParts.length - 1 && <ArticleToc />}
          </>
        ))
      ) : (
        <Fragment set:html={renderedContentHtml} />
      )}
    </BlogMarkdownContent>
  ) : (
    <Default>
      {shouldInsertArticleToc ? (
        contentParts.map((part, index) => (
          <>
            {part && <Fragment set:html={part} />}
            {index < contentParts.length - 1 && <ArticleToc />}
          </>
        ))
      ) : (
        <Fragment set:html={renderedContentHtml} />
      )}
    </Default>
  )
}

<Giscus {...Astro.props} />
