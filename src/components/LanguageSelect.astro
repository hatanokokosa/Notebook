---
import config from "virtual:starlight/user-config";
import Select from "@astrojs/starlight/components/Select.astro";

function localizedPathname(locale: string | undefined): string {
  const url = new URL(Astro.url);
  const locales = config.locales ?? {};
  const base = import.meta.env.BASE_URL.replace(/\/$/, "");
  const pathname =
    base && url.pathname.startsWith(base)
      ? url.pathname.slice(base.length)
      : url.pathname;
  const segments = pathname.split("/").filter(Boolean);

  if (segments[0] && segments[0] in locales) {
    segments[0] = locale ?? "";
  } else if (locale) {
    segments.unshift(locale);
  }

  return `${base}/${segments.filter(Boolean).join("/")}/`.replace(/\/+/g, "/");
}
---

{
  config.isMultilingual && (
    <starlight-lang-select
      data-current-locale={Astro.locals.starlightRoute.locale}
    >
      <Select
        icon="translate"
        label={Astro.locals.t("languageSelect.accessibleLabel")}
        options={Object.entries(config.locales).map(([code, locale]) => ({
          value: localizedPathname(code),
          selected: code === Astro.locals.starlightRoute.locale,
          label: locale!.label,
        }))}
        width="7em"
      />
    </starlight-lang-select>
  )
}

<script src="../plugins/locale.ts"></script>
