---
import type { StarlightBlogEntry } from "../libs/content";
import type { Locale } from "../libs/i18n";

import Preview from "./Preview.astro";

interface Props {
  entries: StarlightBlogEntry[];
  locale: Locale;
}

const { entries, locale } = Astro.props;
---

<div class="posts">
  {entries.map((entry) => <Preview {entry} {locale} />)}
</div>

<script src="../client/giscus-count.ts"></script>

<style>
  .posts {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding-top: 1rem;
  }

  @media (max-width: 49.999em) {
    .posts {
      align-items: center;
    }

    .posts > :global(.preview) {
      width: min(92%, 32rem);
    }
  }
</style>
