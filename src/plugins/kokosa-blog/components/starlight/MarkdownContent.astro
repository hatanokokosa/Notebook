---
import Default from "@astrojs/starlight/components/MarkdownContent.astro";

import { getBlogEntry } from "../../libs/content";
import { isAnyBlogPostPage } from "../../libs/page";
import Metadata from "../Metadata.astro";
import PostTags from "../PostTags.astro";
import PrevNextLinks from "../PrevNextLinks.astro";

const { id, locale } = Astro.locals.starlightRoute;

if (!isAnyBlogPostPage(id)) {
  return null;
}

const { entry, nextLink, prevLink } = await getBlogEntry(id, locale);
---

<Default>
  <Metadata entry={entry} isPost {locale} />
  <slot />
  <div class="post-footer">
    <PostTags entry={entry} {locale} />
    <PrevNextLinks next={nextLink} prev={prevLink} />
  </div>
</Default>

<style>
  .post-footer {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-block-start: 2rem !important;
  }
</style>

<script>
  function applyContentSeparator() {
    const panels = document.querySelectorAll(".content-panel + .content-panel");
    const color = getComputedStyle(document.documentElement).getPropertyValue("--sl-color-hairline").trim() || "#ccc";
    panels.forEach((panel) => {
      panel.style.borderTopStyle = "dashed";
      panel.style.borderTopWidth = "3px";
      panel.style.borderTopColor = color;
    });
  }
  applyContentSeparator();
  document.addEventListener("astro:page-load", applyContentSeparator);
</script>
