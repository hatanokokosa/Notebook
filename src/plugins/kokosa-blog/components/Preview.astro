---
import type { StarlightBlogEntry } from "../libs/content";
import type { Locale } from "../libs/i18n";
import { getLocaleFromPath, getPathWithLocale, getRelativeUrl } from "../libs/page";

import Excerpt from "./Excerpt.astro";
import Metadata from "./Metadata.astro";
import PostTags from "./PostTags.astro";

interface Props {
  entry: StarlightBlogEntry;
  locale: Locale;
}

const { entry, locale } = Astro.props;
const entryPath = `/${getPathWithLocale(entry.id, locale)}`;
const href = getRelativeUrl(entryPath);
const localeSegment = getLocaleFromPath(href);
const giscusTerm = localeSegment ? href.replace(new RegExp(`^/${localeSegment}(?=/|$)`), "") || "/" : href;
const commentCountLabels = {
  "data-comment-one": Astro.locals.t("kokosaBlog.comments.comment_one"),
  "data-comment-other": Astro.locals.t("kokosaBlog.comments.comment_other"),
  "data-reaction-one": Astro.locals.t("kokosaBlog.comments.reaction_one"),
  "data-reaction-other": Astro.locals.t("kokosaBlog.comments.reaction_other"),
  "data-fallback-label": Astro.locals.t("kokosaBlog.comments.fallback"),
};
---

<article class="preview">
  <header>
    <h2>
      <a class="preview-link" {href}>{entry.data.title}</a>
    </h2>
    <Metadata entry={entry} {locale} />
    <PostTags {entry} {locale}>
      <span
        class="comment-count"
        data-giscus-term={giscusTerm}
        aria-label={Astro.locals.t("kokosaBlog.comments.ariaLabel")}
        {...commentCountLabels}
      >
        {Astro.locals.t("kokosaBlog.comments.placeholder")}
      </span>
    </PostTags>
  </header>
  <div class="sl-markdown-content">
    <Excerpt {entry} />
  </div>
</article>

<style>
  .preview {
    display: flex;
    flex-direction: column;
    gap: 0rem;
  }

  header {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  h2 {
    font-size: var(--sl-text-2xl);
    line-height: var(--sl-line-height-headings);
    margin-bottom: 0;
  }

  @media (min-width: 50em) {
    h2 {
      font-size: var(--sl-text-3xl);
    }
  }

  .preview-link {
    text-decoration: none;
  }

  .comment-count {
    color: var(--sl-color-gray-3);
    font-size: var(--sl-text-sm);
  }
</style>
