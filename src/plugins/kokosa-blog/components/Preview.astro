---
import type { StarlightBlogEntry } from "../libs/content";
import type { Locale } from "../libs/i18n";
import { getPathWithLocale, getRelativeUrl } from "../libs/page";

import Cover from "./Cover.astro";
import Excerpt from "./Excerpt.astro";
import Metadata from "./Metadata.astro";
import PostTags from "./PostTags.astro";

interface Props {
  entry: StarlightBlogEntry;
  locale: Locale;
}

const { entry, locale } = Astro.props;
const entryPath = `/${getPathWithLocale(entry.id, locale)}`;
const href = getRelativeUrl(entryPath);
const giscusTerm = href.replace(/^\/(zh-cn|en-us|ja-jp)(?=\/|$)/, "") || "/";
const commentPlaceholder = locale === "ja-jp" ? "コメント ..." : locale === "en-us" ? "Comments ..." : "评论 ...";
---

<article class="preview">
  <header>
    <h2>
      <a class="preview-link" {href}>{entry.data.title}</a>
    </h2>
    {entry.data.cover && <Cover cover={entry.data.cover} />}
    <Metadata entry={entry} {locale} />
    <PostTags {entry} {locale}>
      <span class="comment-count" data-giscus-term={giscusTerm} aria-label="Giscus comments">{commentPlaceholder}</span>
    </PostTags>
  </header>
  <div class="sl-markdown-content">
    <Excerpt {entry} />
  </div>
</article>

<style>
  .preview {
    display: flex;
    flex-direction: column;
    gap: 0rem;
  }

  header {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  h2 {
    margin-bottom: 0;
  }

  .preview-link {
    text-decoration: none;
  }

  .comment-count {
    color: var(--sl-color-gray-3);
    font-size: var(--sl-text-sm);
    margin-inline-start: 0.25rem;
  }
</style>
